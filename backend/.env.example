# =====================================================
# BASE DE DATOS — PostgreSQL (Vercel Postgres / Neon)
# Estas variables las inyecta Vercel automáticamente al vincular la base de datos.
# Para desarrollo local, obtenlas con:  vercel env pull .env
# =====================================================
POSTGRES_PRISMA_URL=postgres://USER:PASSWORD@HOST/db?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://USER:PASSWORD@HOST/db

# =====================================================
# CONFIGURACIÓN DEL SERVIDOR (solo ejecución local / hosts tradicionales)
# En Vercel el puerto lo gestiona la plataforma.
# =====================================================
PORT=3001

# URL pública del frontend (Vercel) para habilitar CORS en producción
# Ej: https://gestion-restaurant.vercel.app
FRONTEND_URL=

# Carpeta de imágenes subidas (no persiste en Vercel serverless)
UPLOADS_DIR="uploads"
