# =====================================================
# CONFIGURACIÓN DE BASE DE DATOS
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
# En producción usa la URL que te da tu proveedor (Railway, etc.)
# =====================================================
DATABASE_URL="mysql://root:root@localhost:3306/gestion_restaurant"

# =====================================================
# CONFIGURACIÓN DEL SERVIDOR
# =====================================================
PORT=3001

# URL pública del frontend (Vercel) para habilitar CORS en producción
# Ej: https://gestion-restaurant.vercel.app
FRONTEND_URL=

# Carpeta donde se guardarán las imágenes subidas
UPLOADS_DIR="uploads"
