# =====================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =====================================================
# Modifica los valores: usuario, contraseña, puerto y nombre de la base de datos
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB

DATABASE_URL="mysql://root:root@localhost:3306/gestion_restaurant"

# =====================================================
# CONFIGURACIÓN DEL SERVIDOR
# =====================================================
PORT=3001

# =====================================================
# CONFIGURACIÓN DE ARCHIVOS
# =====================================================
# Carpeta donde se guardarán las imágenes subidas
UPLOADS_DIR="uploads"
