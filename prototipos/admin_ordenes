<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QUIOSKO Admin - Administrar Órdenes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #f3f4f6; display: flex; min-height: 100vh; }

    /* ─── ADMIN SIDEBAR ─── */
    aside.admin-sidebar {
      width: 288px; min-height: 100vh;
      background: #fff; flex-shrink: 0;
      display: flex; flex-direction: column;
    }
    .logo-wrap { display: flex; justify-content: center; padding: 24px 16px; border-bottom: 1px solid #e5e7eb; }
    .logo-placeholder {
      width: 120px; height: 120px;
      background: linear-gradient(135deg, #fbbf24, #f59e0b);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 36px;
    }
    .nav-label {
      text-align: center; font-size: 12px; font-weight: 700;
      color: #9ca3af; text-transform: uppercase; letter-spacing: 1px;
      margin: 32px 0 12px;
    }
    nav.admin-nav a {
      display: block; padding: 14px 20px;
      text-decoration: none; color: #374151;
      font-weight: 600; font-size: 16px;
      border-left: 4px solid transparent;
      transition: all .15s;
    }
    nav.admin-nav a:hover { background: #f9fafb; }
    nav.admin-nav a.active {
      background: #fef3c7; border-left-color: #f59e0b; color: #92400e;
    }

    /* ─── MAIN CONTENT ─── */
    main.admin-main { flex: 1; background: #f3f4f6; padding: 24px; overflow-y: auto; }
    .page-heading { font-size: 28px; font-weight: 900; color: #111827; margin-bottom: 24px; }

    /* ─── ORDER CARDS GRID ─── */
    .orders-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }

    .order-card {
      background: #f9fafb; border-radius: 8px;
      padding: 24px 24px 20px;
    }
    .order-card .client {
      font-size: 20px; font-weight: 500; color: #111827; margin-bottom: 4px;
    }
    .order-card .products-label {
      font-size: 15px; font-weight: 500; color: #111827; margin-bottom: 16px;
    }
    .products-list { margin-top: 8px; }
    .product-row {
      display: flex; align-items: center; gap: 8px;
      border-top: 1px solid #e5e7eb; padding: 12px 0;
    }
    .product-qty { font-weight: 900; font-size: 14px; color: #4b5563; }
    .product-name { font-size: 14px; color: #111827; font-weight: 500; }

    .total-row {
      display: flex; justify-content: space-between; align-items: center;
      border-top: 1px solid #e5e7eb; padding: 16px 0 0;
      margin-top: 8px;
    }
    .total-row dt { font-size: 16px; font-weight: 500; color: #111827; }
    .total-row dd { font-size: 16px; font-weight: 500; color: #111827; }

    .btn-complete {
      display: block; width: 100%; margin-top: 16px;
      background: #4f46e5; color: #fff;
      border: none; padding: 12px;
      font-weight: 700; font-size: 14px;
      text-transform: uppercase; cursor: pointer;
      border-radius: 2px; letter-spacing: .5px;
    }
    .btn-complete:hover { background: #3730a3; }

    /* Estado vacío */
    .empty-msg { text-align: center; color: #6b7280; font-size: 17px; margin-top: 32px; }
  </style>
</head>
<body>

  <!-- ADMIN SIDEBAR -->
  <aside class="admin-sidebar">
    <div class="logo-wrap">
      <div class="logo-placeholder">🍽️</div>
    </div>
    <p class="nav-label">Navegación</p>
    <nav class="admin-nav">
      <a href="#" class="active">Ordenes</a>
      <a href="#">Productos</a>
      <a href="#" target="_blank">Ver Quiosco</a>
    </nav>
  </aside>

  <!-- CONTENIDO PRINCIPAL -->
  <main class="admin-main">
    <h1 class="page-heading">Administrar ordenes</h1>

    <div class="orders-grid">

      <!-- ORDEN 1 -->
      <section class="order-card">
        <p class="client">Cliente: Juan Pérez</p>
        <p class="products-label">Productos Ordenados:</p>
        <dl class="products-list">
          <div class="product-row">
            <dt class="product-qty">(2)</dt>
            <dd class="product-name">Hamburguesa Clásica</dd>
          </div>
          <div class="product-row">
            <dt class="product-qty">(1)</dt>
            <dd class="product-name">Café Americano</dd>
          </div>
          <div class="product-row">
            <dt class="product-qty">(1)</dt>
            <dd class="product-name">Galletas de Avena</dd>
          </div>
          <div class="total-row">
            <dt>Total a Pagar:</dt>
            <dd>$245.00</dd>
          </div>
        </dl>
        <button class="btn-complete">Marcar Orden Completada</button>
      </section>

      <!-- ORDEN 2 -->
      <section class="order-card">
        <p class="client">Cliente: María García</p>
        <p class="products-label">Productos Ordenados:</p>
        <dl class="products-list">
          <div class="product-row">
            <dt class="product-qty">(1)</dt>
            <dd class="product-name">Pizza Margarita</dd>
          </div>
          <div class="product-row">
            <dt class="product-qty">(2)</dt>
            <dd class="product-name">Café Latte</dd>
          </div>
          <div class="total-row">
            <dt>Total a Pagar:</dt>
            <dd>$190.00</dd>
          </div>
        </dl>
        <button class="btn-complete">Marcar Orden Completada</button>
      </section>

      <!-- ORDEN 3 -->
      <section class="order-card">
        <p class="client">Cliente: Carlos López</p>
        <p class="products-label">Productos Ordenados:</p>
        <dl class="products-list">
          <div class="product-row">
            <dt class="product-qty">(3)</dt>
            <dd class="product-name">Dona Glaseada</dd>
          </div>
          <div class="total-row">
            <dt>Total a Pagar:</dt>
            <dd>$90.00</dd>
          </div>
        </dl>
        <button class="btn-complete">Marcar Orden Completada</button>
      </section>

    </div>
  </main>

</body>
</html>
