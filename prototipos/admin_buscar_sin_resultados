<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QUIOSKO Admin - Sin Resultados de Búsqueda</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #f3f4f6; display: flex; min-height: 100vh; }

    aside.admin-sidebar { width: 288px; min-height: 100vh; background: #fff; flex-shrink: 0; }
    .logo-wrap { display: flex; justify-content: center; padding: 24px 16px; border-bottom: 1px solid #e5e7eb; }
    .logo-placeholder {
      width: 120px; height: 120px;
      background: linear-gradient(135deg, #fbbf24, #f59e0b);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 36px;
    }
    .nav-label {
      text-align: center; font-size: 12px; font-weight: 700;
      color: #9ca3af; text-transform: uppercase; letter-spacing: 1px; margin: 32px 0 12px;
    }
    nav.admin-nav a {
      display: block; padding: 14px 20px;
      text-decoration: none; color: #374151;
      font-weight: 600; font-size: 16px;
      border-left: 4px solid transparent;
    }
    nav.admin-nav a.active { background: #fef3c7; border-left-color: #f59e0b; color: #92400e; }

    main.admin-main { flex: 1; background: #f3f4f6; padding: 24px; overflow-y: auto; }
    .page-heading { font-size: 28px; font-weight: 900; color: #111827; margin-bottom: 24px; }
    .search-badge {
      display: inline-block; background: #fef3c7; color: #92400e;
      padding: 2px 10px; border-radius: 99px;
      font-size: 15px; font-weight: 600; margin-left: 8px;
    }
    .toolbar-end { display: flex; justify-content: flex-end; margin-bottom: 24px; }
    .search-form { display: flex; align-items: center; }
    .search-form input[type="text"] {
      padding: 10px 14px; background: #fff;
      border: 1px solid #d1d5db; font-size: 15px;
      width: 280px; color: #111827; outline: none; border-right: none;
    }
    .search-form input[type="submit"] {
      background: #4f46e5; color: #fff;
      border: none; padding: 10px 20px;
      font-size: 15px; font-weight: 600;
      cursor: pointer; text-transform: uppercase;
    }

    .no-results {
      text-align: center; font-size: 18px;
      color: #6b7280; margin-top: 48px; padding: 32px;
    }
    .no-results span { font-size: 64px; display: block; margin-bottom: 16px; }
  </style>
</head>
<body>

  <aside class="admin-sidebar">
    <div class="logo-wrap">
      <div class="logo-placeholder">🍽️</div>
    </div>
    <p class="nav-label">Navegación</p>
    <nav class="admin-nav">
      <a href="#">Ordenes</a>
      <a href="#" class="active">Productos</a>
      <a href="#">Ver Quiosco</a>
    </nav>
  </aside>

  <main class="admin-main">
    <h1 class="page-heading">
      Resultados de búsqueda:
      <span class="search-badge">sushi</span>
    </h1>

    <div class="toolbar-end">
      <form class="search-form">
        <input type="text" placeholder="Buscar Producto" name="search" value="sushi" />
        <input type="submit" value="Buscar" />
      </form>
    </div>

    <!-- SIN RESULTADOS -->
    <div class="no-results">
      <span>🔍</span>
      No hay resultados
    </div>
  </main>

</body>
</html>
