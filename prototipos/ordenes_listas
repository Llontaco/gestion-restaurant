<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QUIOSKO - Órdenes Listas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #fff;
      min-height: 100vh;
      padding-bottom: 40px;
    }

    .page-title {
      text-align: center;
      margin-top: 80px;
      font-size: 60px;
      font-weight: 900;
      color: #111827;
      letter-spacing: -1px;
    }

    .logo-wrap {
      display: flex; justify-content: center; margin-top: 32px;
    }
    .logo-placeholder {
      width: 140px; height: 140px;
      background: linear-gradient(135deg, #fbbf24, #f59e0b);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 48px;
    }

    .orders-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      max-width: 900px;
      margin: 40px auto 0;
      padding: 0 20px;
    }

    .order-card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.10);
      padding: 20px;
    }

    .order-card .client-name {
      font-size: 22px;
      font-weight: 700;
      color: #475569;
      margin-bottom: 16px;
    }

    .order-card ul {
      list-style: none;
      border-top: 1px solid #e5e7eb;
    }
    .order-card ul li {
      display: flex; padding: 20px 0;
      border-bottom: 1px solid #e5e7eb;
      font-size: 17px;
      color: #374151;
    }
    .order-card ul li span.qty {
      font-weight: 700; margin-right: 8px;
    }

    /* Estado: sin órdenes */
    .no-orders {
      text-align: center;
      margin-top: 60px;
      color: #6b7280;
      font-size: 18px;
    }
  </style>
</head>
<body>

  <h1 class="page-title">Ordenes Listas</h1>

  <div class="logo-wrap">
    <div class="logo-placeholder">🍽️</div>
  </div>

  <!-- GRID DE ÓRDENES LISTAS -->
  <div class="orders-grid">

    <div class="order-card">
      <p class="client-name">Cliente: Juan Pérez</p>
      <ul>
        <li><span class="qty">(2)</span> Hamburguesa Clásica</li>
        <li><span class="qty">(1)</span> Café Americano</li>
        <li><span class="qty">(3)</span> Galletas de Avena</li>
      </ul>
    </div>

    <div class="order-card">
      <p class="client-name">Cliente: María García</p>
      <ul>
        <li><span class="qty">(1)</span> Pizza Margarita</li>
        <li><span class="qty">(2)</span> Café Latte</li>
      </ul>
    </div>

    <div class="order-card">
      <p class="client-name">Cliente: Carlos López</p>
      <ul>
        <li><span class="qty">(1)</span> Pastel de Chocolate</li>
        <li><span class="qty">(1)</span> Dona Glaseada</li>
      </ul>
    </div>

    <div class="order-card">
      <p class="client-name">Cliente: Ana Torres</p>
      <ul>
        <li><span class="qty">(2)</span> Hamburguesa BBQ</li>
        <li><span class="qty">(2)</span> Capuccino</li>
      </ul>
    </div>

  </div>

</body>
</html>
